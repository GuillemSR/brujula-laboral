# App
APP_ENV=local
APP_NAME=brujula-laboral
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# AWS
AWS_REGION=eu-south-2
BEDROCK_MODEL_ID=
BEDROCK_EMBEDDING_MODEL_ID=
S3_TEMP_BUCKET=
S3_CORPUS_BUCKET=
KMS_KEY_ID=

# RAG
RAG_TOP_K=6
RAG_MIN_SCORE=0.2
RAG_VECTOR_BACKEND=local

# Privacy
STORE_USER_PROMPTS=false
STORE_MODEL_RESPONSES=false
STORE_PRIVATE_DOCUMENTS=false
TEMP_DOCUMENT_TTL_MINUTES=30
